# Core runtime configuration
GOOGLE_GENAI_USE_VERTEXAI=<0_or_1>

# Google AI / GCP credentials
GOOGLE_API_KEY=<your-google-ai-studio-api-key>
GOOGLE_CLOUD_PROJECT=<your-gcp-project-id>
GOOGLE_CLOUD_REGION=<your-gcp-region>
DEVELOPER_KNOWLEDGE_API_KEY=<your-developer-knowledge-api-key>

# Optional Anthropic credential
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# Default model tiers
MODEL_MAX_REASONING=<gemini-model-for-deep-reasoning>
MODEL_BALANCED=<gemini-model-for-balanced-tasks>
MODEL_FAST=<gemini-model-for-fast-tasks>
GOOGLE_SEARCH_MODEL=<gemini-model-for-google-search-tool>

# Alternative provider model tiers. Uncomment and replace the default values if you want Anthropic-backed routing instead.
# MODEL_MAX_REASONING=<claude-model-for-deep-reasoning>
# MODEL_BALANCED=<claude-model-for-balanced-tasks>
# MODEL_FAST=<claude-model-for-fast-tasks>
# GOOGLE_SEARCH_MODEL=<gemini-model-for-google-search-tool>

# Remote A2A Agent
KB_AGENT_URL=<your-error-kb-agent-url>

